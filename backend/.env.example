# Dynamic AI Routing Engine – Environment Variables
# Copy this file to .env and fill in real API keys

# ── Server ──────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# ── Traffic API (HERE Maps) ──────────────────────────────────────────────────
# Sign up at https://developer.here.com
TRAFFIC_API_KEY=

# ── Weather API (OpenWeatherMap) ─────────────────────────────────────────────
# Sign up at https://openweathermap.org/api
WEATHER_API_KEY=

# ── ML Model ─────────────────────────────────────────────────────────────────
# Set to "true" to force model retraining on startup
FORCE_RETRAIN=false
